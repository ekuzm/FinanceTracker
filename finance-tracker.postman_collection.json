              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create transfer status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('transfer response contract', function () {",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('fromAccountId');",
                  "  pm.expect(data).to.have.property('toAccountId');",
                  "  pm.expect(data).to.have.property('amount');",
                  "  pm.expect(data).to.have.property('occurredAt');",
                  "  pm.expect(data).to.have.property('note');",
                  "});",
                  "if (data && data.id) pm.collectionVariables.set('transferId', data.id);"
                ]
              }
