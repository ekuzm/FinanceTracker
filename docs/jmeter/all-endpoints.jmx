<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Finance Tracker All Endpoints No Race" enabled="true">
      <stringProp name="TestPlan.comments">CRUD, search, transfer and async flows for Finance Tracker without /demo/race-condition/run</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="host" elementType="Argument">
            <stringProp name="Argument.name">host</stringProp>
            <stringProp name="Argument.value">${__P(host,localhost)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="port" elementType="Argument">
            <stringProp name="Argument.name">port</stringProp>
            <stringProp name="Argument.value">${__P(port,8080)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="protocol" elementType="Argument">
            <stringProp name="Argument.name">protocol</stringProp>
            <stringProp name="Argument.value">${__P(protocol,http)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="basePath" elementType="Argument">
            <stringProp name="Argument.name">basePath</stringProp>
            <stringProp name="Argument.value">${__P(basePath,/api/v1)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="budgetStartDate" elementType="Argument">
            <stringProp name="Argument.name">budgetStartDate</stringProp>
            <stringProp name="Argument.value">${__P(budgetStartDate,2026-04-01)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="budgetEndDate" elementType="Argument">
            <stringProp name="Argument.name">budgetEndDate</stringProp>
            <stringProp name="Argument.value">${__P(budgetEndDate,2026-12-31)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="budgetUpdateEndDate" elementType="Argument">
            <stringProp name="Argument.name">budgetUpdateEndDate</stringProp>
            <stringProp name="Argument.value">${__P(budgetUpdateEndDate,2026-11-30)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="txDateStart" elementType="Argument">
            <stringProp name="Argument.name">txDateStart</stringProp>
            <stringProp name="Argument.value">${__P(txDateStart,2026-04-01)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="txDateEnd" elementType="Argument">
            <stringProp name="Argument.name">txDateEnd</stringProp>
            <stringProp name="Argument.value">${__P(txDateEnd,2026-04-30)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="txOccurredAt" elementType="Argument">
            <stringProp name="Argument.name">txOccurredAt</stringProp>
            <stringProp name="Argument.value">${__P(txOccurredAt,2026-04-05T10:00:00)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="txUpdatedAt" elementType="Argument">
            <stringProp name="Argument.name">txUpdatedAt</stringProp>
            <stringProp name="Argument.value">${__P(txUpdatedAt,2026-04-05T11:30:00)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="transferOccurredAt" elementType="Argument">
            <stringProp name="Argument.name">transferOccurredAt</stringProp>
            <stringProp name="Argument.value">${__P(transferOccurredAt,2026-04-05T12:00:00)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="asyncOccurredAt" elementType="Argument">
            <stringProp name="Argument.name">asyncOccurredAt</stringProp>
            <stringProp name="Argument.value">${__P(asyncOccurredAt,2026-04-05T12:45:00)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="asyncWaitMillis" elementType="Argument">
            <stringProp name="Argument.name">asyncWaitMillis</stringProp>
            <stringProp name="Argument.value">${__P(asyncWaitMillis,3000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="uniqueSuffix" elementType="Argument">
            <stringProp name="Argument.name">uniqueSuffix</stringProp>
            <stringProp name="Argument.value">${__time(yyyyMMddHHmmssSSS,)}_${__threadNum}_${__Random(1000,999999,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="baseUsername" elementType="Argument">
            <stringProp name="Argument.name">baseUsername</stringProp>
            <stringProp name="Argument.value">perf_user_${uniqueSuffix}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="baseEmail" elementType="Argument">
            <stringProp name="Argument.name">baseEmail</stringProp>
            <stringProp name="Argument.value">${baseUsername}@example.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="updatedEmail" elementType="Argument">
            <stringProp name="Argument.name">updatedEmail</stringProp>
            <stringProp name="Argument.value">updated_${uniqueSuffix}@example.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Main">
        <intProp name="ThreadGroup.num_threads">50</intProp>
        <intProp name="ThreadGroup.ramp_time">5</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">5</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
